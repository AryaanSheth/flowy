{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "flowey",
  "version": "0.1.0",
  "identifier": "com.flowey.app",
  "build": {
    "frontendDist": "./frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "settings",
        "title": "Flowey — Settings",
        "url": "index.html",
        "width": 560,
        "height": 640,
        "resizable": false,
        "visible": false,
        "closable": true,
        "decorations": true,
        "center": true,
        "skipTaskbar": true
      }
    ],
"security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "global-shortcut": {},
    "autostart": {},
    "dialog": {}
  }
}
